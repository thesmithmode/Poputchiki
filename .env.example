# Шаблон. Скопируй в .env (local dev) или .env.prod (на сервере) и заполни.
# В CI секреты берутся из GitHub Secrets, не из этого файла.
# Никогда не коммить .env / .env.prod / .env.local — они в .gitignore.

# === Telegram Bot ===
# Получить у @BotFather через /newbot или /token. Никогда не светить.
BOT_TOKEN=
# tg_id владельца (узнать через @userinfobot). Получает роль admin при db:seed.
ADMIN_TG_ID=
# Куда слать админ-алерты. Личный чат с ботом, отдельная группа или канал.
ADMIN_TG_CHAT_ID=
# Секрет для верификации webhook от Telegram (заголовок X-Telegram-Bot-Api-Secret-Token).
# 32+ random bytes. Передаётся в setWebhook secret_token=.
BOT_WEBHOOK_SECRET=

# === Postgres (self-hosted в docker-compose) ===
POSTGRES_USER=poputchiki
POSTGRES_PASSWORD=
POSTGRES_DB=poputchiki
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Composed URL для node-pg-migrate / postgres-js. Пример: postgres://poputchiki:pwd@localhost:5432/poputchiki
DATABASE_URL=
# Отдельные creds для миграций (роль app_migrator с ALTER правами). См. TASK-120.
DATABASE_MIGRATOR_URL=

# === Auth ===
# 32+ random bytes для подписи JWT (HS256). Не светить.
JWT_SECRET=
JWT_ISSUER=poputchiki
JWT_ACCESS_TTL_SECONDS=86400
JWT_REFRESH_TTL_SECONDS=2592000

# === PII шифрование ===
# Ключ для pgp_sym_encrypt (phone, apt_number). 32+ random bytes. Ротация = миграция всех записей.
PGCRYPTO_KEY=

# === Бэкапы ===
# GPG passphrase для шифрования pg_dump бэкапов. Хранить отдельно от БД.
BACKUP_KEY=

# === Reverse proxy / TLS ===
# Доверенные CIDR для X-Forwarded-For (см. TASK-079). По умолчанию docker bridge.
TRUSTED_PROXIES=172.16.0.0/12

# === Domain ===
DOMAIN=poputchiki.searchingforgamesforever.online

# === Deploy / CI (только в GitHub Secrets, не в локальном .env) ===
# GHCR_TOKEN=          # для push docker images в ghcr.io
# SSH_HOST=            # IP/hostname сервера
# SSH_USER=            # пользователь для deploy
# SSH_KEY=             # приватный SSH-ключ (multiline, base64 либо raw)

# === Observability (опц., если поднят profile observability) ===
# SENTRY_DSN_API=
# SENTRY_DSN_WEB=
# GRAFANA_ADMIN_PASSWORD=
# PROMETHEUS_BASIC_AUTH=  # формат user:hash (htpasswd)
