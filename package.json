{
  "name": "poputchiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*", "web"],
  "dependencies": {
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "node-pg-migrate": "^8.0.4"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "coverage:integration": "vitest run --config vitest.integration.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:web": "bun run --filter @poputchiki/web test",
    "dev:web": "bun run --filter @poputchiki/web dev",
    "coverage:check": "vitest run --coverage",
    "build": "bun run --filter '*' build",
    "db:migrate": "DATABASE_URL=${DATABASE_MIGRATOR_URL:-$DATABASE_URL} node-pg-migrate up --migrations-dir db/migrations --migration-file-language sql",
    "db:migrate:down": "DATABASE_URL=${DATABASE_MIGRATOR_URL:-$DATABASE_URL} node-pg-migrate down --migrations-dir db/migrations --migration-file-language sql",
    "db:migrate:create": "node-pg-migrate create --migrations-dir db/migrations --migration-file-language sql",
    "db:seed": "bun run scripts/db-seed.ts",
    "db:reset": "bash scripts/db-reset.sh",
    "test:contract": "vitest run apps/*/tests/contract"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "^1.3.13",
    "config": "^4.4.1",
    "pg": "^8.20.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5",
    "zod-to-json-schema": "^3.25.2"
  }
}
